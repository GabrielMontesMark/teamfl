<odoo>

    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <field name="cai" readonly="1" invisible="not cai"/>
                <field name="fecha_desde" readonly="1" invisible="not cai"/>
                <field name="fecha_hasta" readonly="1" invisible="not cai"/>
                <field name="correlativo_desde" readonly="1" invisible="not cai"/>
                <field name="correlativo_hasta" readonly="1" invisible="not cai"/>
            </xpath>
        </field>
    </record>

</odoo>
