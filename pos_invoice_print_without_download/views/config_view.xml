<odoo>
    <record id="res_config_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='point_of_sale']" position="inside">
                <block title="Invoice Print Options" id="pos_invoice_print_block">
                    <setting id="pos_invoice_print_id" string="Print Invoice Without its Download" help="Allows to Print Invoice Without Download. Disable to download invoice.">
                        <field name="pos_invoice_print"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>